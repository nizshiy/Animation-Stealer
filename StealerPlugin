CreateBtn.TextColor3 = Color3.new(1, 1, 1)
CreateBtn.Font = Enum.Font.GothamBold
CreateBtn.Parent = mainFrame

local jointToPart = {
	["Neck"] = "Head",
	["Right Shoulder"] = "Right Arm",
	["Left Shoulder"] = "Left Arm",
	["Right Hip"] = "Right Leg",
	["Left Hip"] = "Left Leg"
}

local function createAnimation()
	local rawData = InputBox.Text
	if rawData == "" then return end

	local success, data = pcall(function() return HttpService:JSONDecode(rawData) end)

	if not success then
		CreateBtn.Text = "JSON ERROR!"
		CreateBtn.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
		task.wait(1.5)
		CreateBtn.Text = "CREATE KEYFRAMESEQUENCE"
		CreateBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
		return
	end

	local fps = data.FPS or 30
	local keyframeSequence = Instance.new("KeyframeSequence")
	keyframeSequence.Name = "R6_Anim_" .. os.time()

	for i, frameData in ipairs(data.Frames) do
		local keyframe = Instance.new("Keyframe")
		keyframe.Time = (i - 1) / fps
		keyframe.Name = "Keyframe" .. i
		keyframe.Parent = keyframeSequence

		local rootPose = Instance.new("Pose")
		rootPose.Name = "HumanoidRootPart"
		rootPose.Parent = keyframe

		local torsoPose = Instance.new("Pose")
		torsoPose.Name = "Torso"
		if frameData["RootJoint"] then
			torsoPose.CFrame = CFrame.new(unpack(frameData["RootJoint"]))
		end
		torsoPose.Parent = rootPose

		for jointName, cfArray in pairs(frameData) do
			if jointName ~= "RootJoint" then
				local partName = jointToPart[jointName]
				if partName then
					local p = Instance.new("Pose")
					p.Name = partName
					p.CFrame = CFrame.new(unpack(cfArray))
					p.Parent = torsoPose
				end
			end
		end
	end

	keyframeSequence.Parent = game.Workspace
	Selection:Set({keyframeSequence})

	CreateBtn.Text = "DONE: SAVED IN WORKSPACE"
	CreateBtn.BackgroundColor3 = Color3.fromRGB(0, 160, 0)
	task.wait(2)
	CreateBtn.Text = "CREATE KEYFRAMESEQUENCE"
	CreateBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
end

CreateBtn.MouseButton1Click:Connect(createAnimation)
button.Click:Connect(function() widget.Enabled = not widget.Enabled end)
